    <string name="notification_permission_title">Cho phép thông báo</string>
    <string name="notification_permission_rationale">Tiện ích thông báo hiển thị giờ cầu nguyện trong khay thông báo của bạn. Cho phép thông báo để bật nó.</string>
    <string name="notification_permission_denied_text">Cần quyền truy cập thông báo để hiển thị tiện ích. Bật thông báo cho ứng dụng này trong cài đặt.</string>
    <string name="exact_alarm_permission_title">Cho phép báo thức chính xác</string>
    <string name="exact_alarm_permission_rationale">Để giữ giờ cầu nguyện và đồng hồ đếm ngược của tiện ích được chính xác, hãy cho phép ứng dụng này lên lịch báo thức chính xác.</string>
    <string name="exact_alarm_permission_denied_text">Cần quyền báo thức chính xác để giữ giờ cầu nguyện và đồng hồ đếm ngược của tiện ích được chính xác. Cho phép nó cho ứng dụng này trong cài đặt.</string>
    <string name="full_screen_intent_permission_title">Cho phép báo thức toàn màn hình</string>
    <string name="adhan_notification_permission_rationale">Báo thức Azan đăng một thông báo vào mỗi giờ cầu nguyện. Cho phép thông báo để bật chúng.</string>
    <string name="adhan_notification_permission_denied_text">Cần quyền truy cập thông báo cho báo thức Azan. Bật thông báo cho ứng dụng này trong cài đặt.</string>
    <string name="adhan_exact_alarm_permission_rationale">Báo thức Azan phải kích hoạt vào đúng giờ cầu nguyện. Cho phép ứng dụng này lên lịch báo thức chính xác.</string>
    <string name="adhan_exact_alarm_permission_denied_text">Cần quyền báo thức chính xác để báo thức Azan kích hoạt đúng giờ. Cho phép nó cho ứng dụng này trong cài đặt.</string>
    <string name="adhan_full_screen_intent_permission_rationale">Để hiển thị báo thức Azan trên màn hình khóa và đánh thức màn hình, hãy cho phép ứng dụng này sử dụng báo thức toàn màn hình.</string>
    <string name="adhan_full_screen_intent_permission_denied_text">Nếu không có quyền toàn màn hình, báo thức Azan sẽ không hiển thị trên màn hình khóa. Bạn có thể cho phép nó sau trong cài đặt.</string>
    <string name="adhan_phone_state_permission_rationale">Cho phép truy cập điện thoại để Azan có thể tạm dừng khi có cuộc gọi đến hoặc đang diễn ra. Chỉ dùng để đọc trạng thái cuộc gọi.</string>
    <string name="adhan_phone_state_permission_denied_text">Quyền truy cập điện thoại đang tắt, nên Azan sẽ không tạm dừng khi có cuộc gọi. Bạn có thể cho phép nó sau trong cài đặt.</string>
    <string name="reminder_notification_permission_rationale">Lời nhắc đăng một thông báo vào thời gian đã lên lịch. Cho phép thông báo để bật chúng.</string>
    <string name="reminder_notification_permission_denied_text">Cần quyền truy cập thông báo cho lời nhắc. Bật thông báo cho ứng dụng này trong cài đặt.</string>
    <string name="reminder_exact_alarm_permission_rationale">Lời nhắc phải kích hoạt vào đúng thời gian đã lên lịch. Cho phép ứng dụng này lên lịch báo thức chính xác.</string>
    <string name="reminder_exact_alarm_permission_denied_text">Cần quyền báo thức chính xác để lời nhắc kích hoạt đúng giờ. Cho phép nó cho ứng dụng này trong cài đặt.</string>
    <string name="phone_state_permission_title">Cho phép truy cập điện thoại</string>
    <string name="dnd_permission_title">Cho phép truy cập Không làm phiền</string>
    <string name="dnd_permission_rationale">Cho phép ứng dụng này điều khiển chế độ Không làm phiền. Điều này cho phép Azan phát ngay cả khi Không làm phiền đang bật, và bật tùy chọn tắt tiếng điện thoại sau khi bạn bỏ qua báo thức.</string>
    <string name="dnd_permission_denied_text">Tính năng này yêu cầu quyền truy cập Không làm phiền. Cho phép nó cho ứng dụng này trong cài đặt.</string>
    <string name="home_notification_permission_rationale">Thông báo đã bị tắt. Cho phép lại để báo thức Azan có thể đến với bạn.</string>
    <string name="home_exact_alarm_permission_rationale">Quyền báo thức chính xác đã bị tắt. Cho phép lại để báo thức cầu nguyện của bạn tiếp tục kích hoạt đúng giờ.</string>

