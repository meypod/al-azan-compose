    <string name="notification_permission_denied_text">উইজেট দেখানোর জন্য নোটিফিকেশনের অ্যাক্সেস প্রয়োজন। সেটিংসে এই অ্যাপের জন্য নোটিফিকেশন সক্রিয় করুন।</string>
    <string name="exact_alarm_permission_title">সুনির্দিষ্ট অ্যালার্মের অনুমতি দিন</string>
    <string name="exact_alarm_permission_rationale">উইজেটের সালাতের সময় ও কাউন্টডাউন সঠিক রাখতে এই অ্যাপকে সুনির্দিষ্ট অ্যালার্ম নির্ধারণের অনুমতি দিন।</string>
    <string name="exact_alarm_permission_denied_text">উইজেটের সালাতের সময় ও কাউন্টডাউন সঠিক রাখতে সুনির্দিষ্ট অ্যালার্মের অ্যাক্সেস প্রয়োজন। সেটিংসে এই অ্যাপের জন্য এটি অনুমোদন করুন।</string>
    <string name="full_screen_intent_permission_title">ফুল-স্ক্রিন অ্যালার্মের অনুমতি দিন</string>
    <string name="adhan_notification_permission_rationale">আযান অ্যালার্ম প্রতিটি সালাতের সময়ে একটি নোটিফিকেশন পোস্ট করে। এগুলো সক্রিয় করতে নোটিফিকেশনের অনুমতি দিন।</string>
    <string name="adhan_notification_permission_denied_text">আযান অ্যালার্মের জন্য নোটিফিকেশনের অ্যাক্সেস প্রয়োজন। সেটিংসে এই অ্যাপের জন্য নোটিফিকেশন সক্রিয় করুন।</string>
    <string name="adhan_exact_alarm_permission_rationale">আযান অ্যালার্ম অবশ্যই সুনির্দিষ্ট সালাতের সময়ে বাজতে হবে। এই অ্যাপকে সুনির্দিষ্ট অ্যালার্ম নির্ধারণের অনুমতি দিন।</string>
    <string name="adhan_exact_alarm_permission_denied_text">আযান অ্যালার্ম সময়মতো বাজার জন্য সুনির্দিষ্ট অ্যালার্মের অ্যাক্সেস প্রয়োজন। সেটিংসে এই অ্যাপের জন্য এটি অনুমোদন করুন।</string>
    <string name="adhan_full_screen_intent_permission_rationale">আপনার লক স্ক্রিনের উপর আযান অ্যালার্ম দেখাতে এবং ডিসপ্লে জাগাতে এই অ্যাপকে ফুল-স্ক্রিন অ্যালার্ম ব্যবহারের অনুমতি দিন।</string>
    <string name="adhan_full_screen_intent_permission_denied_text">ফুল-স্ক্রিন অ্যাক্সেস ছাড়া আযান অ্যালার্ম লক স্ক্রিনের উপর দেখাবে না। আপনি পরে সেটিংসে এটি অনুমোদন করতে পারেন।</string>
    <string name="adhan_phone_state_permission_rationale">ইনকামিং বা চলমান কলের জন্য আযান যেন থামতে পারে সেজন্য ফোনের অ্যাক্সেস দিন। শুধুমাত্র কল স্ট্যাটাস পড়তে এটি ব্যবহৃত হয়।</string>
    <string name="adhan_phone_state_permission_denied_text">ফোনের অ্যাক্সেস বন্ধ, তাই কলের জন্য আযান থামবে না। আপনি পরে সেটিংসে এটি অনুমোদন করতে পারেন।</string>
    <string name="reminder_notification_permission_rationale">রিমাইন্ডার নির্ধারিত সময়ে একটি নোটিফিকেশন পোস্ট করে। এগুলো সক্রিয় করতে নোটিফিকেশনের অনুমতি দিন।</string>
    <string name="reminder_notification_permission_denied_text">রিমাইন্ডারের জন্য নোটিফিকেশনের অ্যাক্সেস প্রয়োজন। সেটিংসে এই অ্যাপের জন্য নোটিফিকেশন সক্রিয় করুন।</string>
    <string name="reminder_exact_alarm_permission_rationale">রিমাইন্ডার অবশ্যই সুনির্দিষ্ট নির্ধারিত সময়ে বাজতে হবে। এই অ্যাপকে সুনির্দিষ্ট অ্যালার্ম নির্ধারণের অনুমতি দিন।</string>
    <string name="reminder_exact_alarm_permission_denied_text">রিমাইন্ডার সময়মতো বাজার জন্য সুনির্দিষ্ট অ্যালার্মের অ্যাক্সেস প্রয়োজন। সেটিংসে এই অ্যাপের জন্য এটি অনুমোদন করুন।</string>
    <string name="reminder_full_screen_intent_permission_rationale">আপনার লক স্ক্রিনের উপর রিমাইন্ডার দেখাতে এবং ডিসপ্লে জাগাতে এই অ্যাপকে ফুল-স্ক্রিন অ্যালার্ম ব্যবহারের অনুমতি দিন।</string>
    <string name="reminder_full_screen_intent_permission_denied_text">ফুল-স্ক্রিন অ্যাক্সেস ছাড়া রিমাইন্ডার লক স্ক্রিনের উপর দেখাবে না। আপনি পরে সেটিংসে এটি অনুমোদন করতে পারেন।</string>
    <string name="reminder_phone_state_permission_rationale">ইনকামিং বা চলমান কলের জন্য রিমাইন্ডার যেন থামতে পারে সেজন্য ফোনের অ্যাক্সেস দিন। শুধুমাত্র কল স্ট্যাটাস পড়তে এটি ব্যবহৃত হয়।</string>
    <string name="reminder_phone_state_permission_denied_text">ফোনের অ্যাক্সেস বন্ধ, তাই কলের জন্য রিমাইন্ডার থামবে না। আপনি পরে সেটিংসে এটি অনুমোদন করতে পারেন।</string>
    <string name="phone_state_permission_title">ফোনের অ্যাক্সেস দিন</string>
    <string name="dnd_permission_title">ডু নট ডিস্টার্ব অ্যাক্সেস দিন</string>
    <string name="dnd_permission_rationale">এই অ্যাপকে ডু নট ডিস্টার্ব নিয়ন্ত্রণের অনুমতি দিন। এটি ডু নট ডিস্টার্ব চালু থাকা অবস্থায়ও আযান বাজাতে দেয় এবং অ্যালার্ম খারিজ করার পর আপনার ফোন নীরব করার অপশন সক্রিয় করে।</string>
    <string name="dnd_permission_denied_text">এর জন্য ডু নট ডিস্টার্ব অ্যাক্সেস প্রয়োজন। সেটিংসে এই অ্যাপের জন্য এটি অনুমোদন করুন।</string>
    <string name="home_notification_permission_rationale">নোটিফিকেশন বন্ধ করা হয়েছিল। আযান অ্যালার্ম যেন আপনার কাছে পৌঁছায় সেজন্য আবার অনুমতি দিন।</string>
    <string name="home_exact_alarm_permission_rationale">সুনির্দিষ্ট অ্যালার্মের অ্যাক্সেস বন্ধ করা হয়েছিল। আপনার সালাতের অ্যালার্ম যেন সময়মতো বাজতে থাকে সেজন্য আবার অনুমতি দিন।</string>
    <string name="battery_optimization_permission_title">অ্যালার্ম নির্ভরযোগ্য রাখুন</string>
    <string name="battery_optimization_permission_rationale">আপনার অ্যালার্মগুলো নির্ভরযোগ্যভাবে পৌঁছে দিতে, এই অ্যাপটিকে ব্যাকগ্রাউন্ডে চালু থাকার অনুমতি দিন। এটি ছাড়া, ব্যাটারি বাঁচাতে সিস্টেম এটি বন্ধ করে দিতে পারে এবং অ্যালার্ম দেরিতে বাজতে পারে বা মিস হতে পারে।</string>
    <string name="battery_optimization_permission_denied_text">ব্যাটারি অপ্টিমাইজেশন এখনও চালু আছে, তাই অ্যালার্ম দেরিতে বাজতে পারে বা মিস হতে পারে। আপনি পরে সেটিংসে এটি অনুমতি দিতে পারেন।</string>

